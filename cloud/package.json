{
  "name": "flowix-cloud",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Flowix cloud sync server — Cloudflare Workers + D1 + R2",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply flowix-cloud --local",
    "db:migrate:remote": "wrangler d1 migrations apply flowix-cloud --remote",
    "db:query:local": "wrangler d1 execute flowix-cloud --local --command",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@noble/hashes": "^1.6.0",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "stripe": "^17.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@cloudflare/workers-types": "^4.20241205.0",
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10",
    "wrangler": "^3.93.0"
  }
}
