# 本地开发 secrets。复制为 .dev.vars(wrangler dev 会注入)。
# 线上用 `wrangler secret put <NAME>` 注入,不要提交 .dev.vars。

# --- JWT RS256 密钥对 ---
# 生成:
#   openssl genpkey -algorithm RSA -out jwt.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in jwt.pem -pubout -out jwt.pub.pem
# 然后把 PEM 内容(含换行)整段粘进来:
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
MIIE...
-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
MIIB...
-----END PUBLIC KEY-----"

# --- Stripe(测试模式) ---
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# --- Cloudflare Turnstile(可选,留空则跳过校验,适合本地开发) ---
# 生产:Dashboard 创建 Turnstile site,把 secret 填这里
TURNSTILE_SECRET_KEY=""

# --- 内部 GC 路由鉴权 ---
# 任意强随机串;调用 /internal/gc 时带 header x-internal-secret: <同值>
GC_SECRET="change-me-to-a-long-random-string"

# --- 限流开关(仅测试用;生产留空/不设 = 启用限流)---
RATE_LIMIT_DISABLED=""
