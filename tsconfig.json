{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["app/flowix-web/*"],
      "@app/*": ["app/flowix-web/app/*"],
      "@features/*": ["app/flowix-web/features/*"],
      "@platform/*": ["app/flowix-web/platform/*"],
      "@shared/*": ["app/flowix-web/shared/*"]
    },
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["app/flowix-web"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
